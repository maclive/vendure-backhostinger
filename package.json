{
  "name": "vendure-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:server": "ts-node ./src/index.ts",
    "dev:worker": "ts-node ./src/index-worker.ts",
    "dev": "concurrently npm:dev:*",
    "build": "tsc",
    "start:server": "node ./dist/index.js",
    "start:worker": "node ./dist/index-worker.js",
    "start": "concurrently npm:start:*",
    "start:hostinger": "node ./dist/index-hostinger.js"
  },
  "dependencies": {
    "@vendure/asset-server-plugin": "3.5.1",
    "@vendure/core": "3.5.1",
    "@vendure/dashboard": "3.5.1",
    "@vendure/email-plugin": "3.5.1",
    "@vendure/graphiql-plugin": "3.5.1",
    "better-sqlite3": "12.4.1",
    "dotenv": "17.2.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@vendure/cli": "3.5.1",
    "concurrently": "9.2.1",
    "typescript": "5.8.2"
  }
}
